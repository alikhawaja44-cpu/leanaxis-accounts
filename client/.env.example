# For local dev — leave blank (Vite proxy handles /api → localhost:3001)
VITE_API_URL=

# For production (GitHub Pages) — set this to your deployed backend URL
# e.g. if using Railway: https://leanaxis-server.up.railway.app/api
# e.g. if using Render:  https://leanaxis-server.onrender.com/api
# VITE_API_URL=https://your-server.railway.app/api
